{
  "name": "eslint-config-tidgi",
  "version": "3.0.0",
  "description": "Eslint config fot TidGi and its plugins, with many eslint plugins to perform auto-fix.",
  "homepage": "https://github.com/tiddly-gittly/eslint-config-tidgi",
  "bugs": "https://github.com/tiddly-gittly/eslint-config-tidgi/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/tiddly-gittly/eslint-config-tidgi"
  },
  "license": "MIT",
  "keywords": [
    "eslint",
    "tiddlywiki",
    "tidgi",
    "tiddlywiki-plugin",
    "tiddlywiki5",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "update": "npm-check-updates -u && dprint config update",
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "lint": "eslint ./src",
    "check": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@dprint/json": "^0.21.3",
    "@dprint/typescript": "^0.96.1",
    "@eslint-react/eslint-plugin": "^5.8.16",
    "@eslint/js": "^10.0.1",
    "dprint": "^0.54.0",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-security-node": "1.1.4",
    "eslint-plugin-unicorn": "65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@modern-js/tsconfig": "^3.2.2",
    "@types/node": "^25.9.2",
    "jiti": "^2.7.0",
    "npm-check-updates": "^22.2.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.3.3 || ^6.0.0"
  },
  "pnpm": {
    "overrides": {
      "eslint": "$eslint"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "$eslint"
      }
    },
    "onlyBuiltDependencies": [
      "dprint",
      "unrs-resolver"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "eslint.config.js",
    "eslint.config.d.ts",
    "tsconfig.json",
    "tsconfig.eslint.json",
    "dprint.json"
  ],
  "main": "eslint.config.js",
  "exports": {
    ".": "./eslint.config.js"
  }
}
